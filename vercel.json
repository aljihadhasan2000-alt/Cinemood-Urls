{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/create",
      "destination": "/api/create.ts"
    },
    {
      "source": "/api/trending",
      "destination": "/api/trending.ts"
    },
    {
      "source": "/api/collections/:slug/verify-password",
      "destination": "/api/verify-password.ts?slug=:slug"
    },
    {
      "source": "/api/collections/:slug/links/:linkId/click",
      "destination": "/api/click.ts?slug=:slug&linkId=:linkId"
    },
    {
      "source": "/api/collections/:slug",
      "destination": "/api/collections-router.ts?slug=:slug"
    },
    {
      "source": "/p/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/success/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/analytics/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon.ico|database.json|api/).*)*",
      "destination": "/index.html"
    }
  ]
}
