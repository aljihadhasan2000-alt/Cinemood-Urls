{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/get/:slug",
      "destination": "/api/get/[slug].ts?slug=:slug"
    },
    {
      "source": "/api/delete/:slug",
      "destination": "/api/delete/[slug].ts?slug=:slug"
    },
    {
      "source": "/api/collections/:slug/verify-password",
      "destination": "/api/collections/[slug]/verify-password.ts?slug=:slug"
    },
    {
      "source": "/api/collections/:slug/links/:linkId/click",
      "destination": "/api/collections/[slug]/links/[linkId]/click.ts?slug=:slug&linkId=:linkId"
    },
    {
      "source": "/api/collections/:slug",
      "destination": "/api/collections/[slug].ts?slug=:slug"
    },
    {
      "source": "/p/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/success/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/analytics/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon.ico|database.json|api/).*)*",
      "destination": "/index.html"
    }
  ]
}
