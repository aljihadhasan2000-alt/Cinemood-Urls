{
  "version": 2,
  "rewrites": [
    {
      "source": "/p/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/success/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/analytics/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/((?!assets/|favicon.ico|database.json|api/).*)*",
      "destination": "/index.html"
    }
  ]
}
